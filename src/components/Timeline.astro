---
import Video from '@/components/Video.astro';

interface TimelineEvent {
	time: string;
	text: string;
	image?: string;
	video?: string;
	link?: string;
}

interface Props {
	events: Array<TimelineEvent>;
	reverse?: boolean;
}
const { events, reverse } = Astro.props;
if (reverse) {
	events.reverse();
}

const dotColors = ['bg-marigold', 'bg-tomato', 'bg-grape', 'bg-pine', 'bg-sky'];
---

<style>
	.timeline-item > .timeline-card {
		visibility: hidden;
		opacity: 0;
		transform: translateY(18px);
		transition:
			transform 0.5s cubic-bezier(0.2, 0.7, 0.3, 1),
			opacity 0.5s cubic-bezier(0.2, 0.7, 0.3, 1);
	}

	.timeline-item.in-view > .timeline-card {
		visibility: visible;
		opacity: 1;
		transform: translateY(0);
	}

	.timeline-item.in-view > .timeline-node {
		transform: translate(-50%, -50%) scale(1.15);
	}

	@media (prefers-reduced-motion: reduce) {
		.timeline-item > .timeline-card {
			visibility: visible;
			opacity: 1;
			transform: none;
		}
	}
</style>

<script>
	(() => {
		const items = document.querySelectorAll('.timeline-item');

		const observer = new IntersectionObserver(
			entries => {
				for (const entry of entries) {
					if (entry.isIntersecting) {
						entry.target.classList.add('in-view');
					}
				}
			},
			{
				root: null,
				threshold: 0.5,
			},
		);

		for (const item of items) {
			observer.observe(item);
		}
	})();
</script>

<section class="timeline not-prose">
	<ul class="relative mx-auto max-w-2xl list-none px-0 py-8 before:absolute before:top-0 before:bottom-0 before:left-3 before:w-[3px] before:bg-ink before:content-['']">
		{
			events.map((event, i) => (
				<li class="timeline-item relative my-0 list-none pl-10 pb-10 last:pb-0">
					<span
						class:list={[
							'timeline-node absolute top-3 left-3 z-10 size-4 -translate-x-1/2 -translate-y-1/2 rounded-full border-2 border-ink transition-transform duration-500 ease-out',
							dotColors[i % dotColors.length],
						]}
					/>
					<div class="timeline-card rounded-[14px] border-2 border-ink bg-card p-4 shadow-hard-sm">
						<time class="block font-mono text-sm font-bold tracking-wide text-ink-soft uppercase">
							{event.time}
						</time>
						{event.text && <p class="mt-2 mb-0 font-display font-bold text-ink">{event.text}</p>}
						{event.image && (
							<div class="mt-3 flex items-center justify-center">
								<img
									src={event.image}
									alt={event.text}
									class="max-h-36 rounded-[10px] border-2 border-ink shadow-hard-sm"
								/>
							</div>
						)}
						{event.link && (
							<a
								href={event.link}
								class="mt-3 inline-flex font-display font-bold text-tomato underline decoration-ink decoration-2 underline-offset-2 hover:decoration-tomato"
							>
								Link →
							</a>
						)}
						{event.video && (
							<div class="mt-3">
								<Video videoId={event.video} />
							</div>
						)}
					</div>
				</li>
			))
		}
	</ul>
</section>
