---
import { Icon } from 'astro-icon/components';

interface Props {
	title: string;
	url: string;
	icon?: string | undefined;
}
const { title, url, icon } = Astro.props;
---

<a
	href={url}
	target="_blank"
	rel="noopener noreferrer"
	data-type="social-link"
	class="tactile mx-auto flex w-full max-w-sm items-center gap-3 rounded-[10px] border-2 border-ink bg-card p-4 py-3 font-display font-bold text-ink no-underline shadow-hard"
>
	{
		icon && (
			<div class="flex w-6 justify-center">
				<Icon name={icon} class="inline-block size-6" />
			</div>
		)
	}
	{title}
</a>
