---
import metadata from '../data/metadata.json';
import { DateTime } from 'luxon';
import { Icon } from 'astro-icon/components';
const year = DateTime.local().year;
---

<footer class="border-t border-transparent bg-gray-50 px-6 dark:bg-dark-surface/30">
	<!-- Gradient border line -->
	<div class="mx-auto h-px max-w-5xl bg-gradient-to-r from-transparent via-purple-500/50 to-transparent"></div>

	<div class="mx-auto max-w-5xl">
		<div class="grid grid-cols-1 gap-8 border-gray-200 py-12 sm:grid-cols-3">
			<div class="sm:pb-8">
				<div class="pb-3 font-medium">
					<Icon name="ic:baseline-email" class="inline-block h-5 w-5" /> Drop me an email!
				</div>
				<a
					target="_blank"
					href={`mailto:${metadata.author.email}`}
					class="text-gray-500 no-underline hover:text-gray-600 hover:underline">{metadata.author.email}</a
				>
				<div class="py-3">© {metadata.author.name} {year}</div>
			</div>
			<div class="">
				<div class="pb-3">
					<a class="text-gray-500 no-underline hover:text-gray-600 hover:underline" href="/">Home</a>
				</div>
				<div class="pb-3">
					<a class="text-gray-500 no-underline hover:text-gray-600 hover:underline" href="/about">About</a>
				</div>
				<div class="pb-3">
					<a class="text-gray-500 no-underline hover:text-gray-600 hover:underline" href="/posts">Posts</a>
				</div>
			</div>
			<div>
				<div class="pb-3">
					<a class="text-gray-500 no-underline hover:text-gray-600 hover:underline" href="/talks">Talks</a>
				</div>
				<div class="pb-3">
					<a class="text-gray-500 no-underline hover:text-gray-600 hover:underline" href="/uses">Uses</a>
				</div>
				<div class="flex pt-2">
					<div class="flex">
						{
							Object.entries(metadata.social)
								.filter(([, { hidden }]) => !hidden)
								.map(([name, { url }]) => (
									<div class="px-1">
										<a target="_blank" href={url} class="hover-glow rounded-md text-gray-500 no-underline transition-colors hover:text-purple-700 dark:hover:text-purple-300">
											<Icon
												name={`simple-icons:${name}`}
												class="inline-block h-5 w-5"
											/>
										</a>
									</div>
								))
						}
					</div>
				</div>
			</div>
		</div>
	</div>
</footer>
