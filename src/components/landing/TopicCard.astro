---
import { Icon } from 'astro-icon/components';

interface Props {
	icon: string;
	title: string;
	description: string;
	number?: number;
	accent?: 'tomato' | 'grape' | 'pine' | 'sky' | 'marigold';
}

const { icon, title, description, number, accent = 'marigold' } = Astro.props;

const fill: Record<string, string> = {
	tomato: 'bg-tomato text-paper',
	grape: 'bg-grape text-paper',
	pine: 'bg-pine text-ink',
	sky: 'bg-sky text-ink',
	marigold: 'bg-marigold text-ink',
};
const iconColor: Record<string, string> = {
	tomato: 'text-tomato',
	grape: 'text-grape',
	pine: 'text-pine',
	sky: 'text-sky',
	marigold: 'text-ink',
};
---

<div class="tactile relative rounded-[14px] border-2 border-ink bg-card p-6 shadow-hard-sm">
	{
		number && (
			<div
				class:list={[
					'absolute -top-3 -right-3 grid h-9 w-9 -rotate-3 place-items-center rounded-full border-2 border-ink font-display text-sm font-extrabold shadow-hard-sm',
					fill[accent],
				]}
			>
				{number}
			</div>
		)
	}
	<Icon name={icon} class:list={['mb-3 size-9', iconColor[accent]]} />
	<h3 class="p-0 font-display text-lg font-bold text-ink">{title}</h3>
	<p class="mt-1.5 text-sm text-ink-soft">{description}</p>
</div>
