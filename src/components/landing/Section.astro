---
interface Props {
	id?: string;
	variant?: 'default' | 'muted' | 'accent' | 'dark' | 'hero';
	class?: string;
	narrow?: boolean;
}

const { id, variant = 'default', class: className, narrow } = Astro.props;

// Reserved, deliberate color per section. Light-first; dark mode flips
// automatically via the semantic tokens. No gradients, no glass, no glow.
const bgClasses: Record<string, string> = {
	default: 'bg-paper text-ink',
	muted: 'bg-paper-2 text-ink',
	accent: 'bg-marigold text-ink',
	dark: 'slab-dark bg-ink text-paper',
	hero: 'relative overflow-hidden bg-paper text-ink',
};
---

<section id={id} class:list={[bgClasses[variant], className]}>
	<div
		class:list={[
			'mx-auto px-6',
			variant === 'hero' ? 'py-20 md:py-28' : 'py-16 md:py-20',
			narrow ? 'max-w-3xl' : 'max-w-5xl',
		]}
	>
		<slot />
	</div>
</section>
