---
interface Props {
	quote: string;
	author: string;
	role?: string;
	company?: string;
}

const { quote, author, role, company } = Astro.props;
---

<figure class="relative rounded-[14px] border-2 border-ink bg-card p-8 shadow-hard">
	<span
		class="absolute -top-4 left-6 grid h-9 w-12 -rotate-2 place-items-center rounded-full border-2 border-ink bg-marigold font-display text-2xl leading-none font-extrabold text-ink shadow-hard-sm"
		aria-hidden="true"
	>
		&ldquo;
	</span>
	<blockquote class="mt-2 font-display text-xl leading-relaxed font-bold text-ink">
		{quote}
	</blockquote>
	<figcaption class="mt-6 flex items-center gap-3">
		<span class="h-2.5 w-2.5 rounded-full border-[1.5px] border-ink bg-tomato"></span>
		<span class="font-display font-bold text-ink">{author}</span>
		{
			(role || company) && (
				<span class="font-mono text-xs text-ink-soft">{[role, company].filter(Boolean).join(' · ')}</span>
			)
		}
	</figcaption>
</figure>
