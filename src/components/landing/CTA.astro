---
interface Props {
	email?: string;
	subject?: string;
	label: string;
	variant?: 'primary' | 'secondary';
	href?: string;
}

const { email, subject, label, variant = 'primary', href: hrefProp } = Astro.props;

const href = hrefProp ?? `mailto:${email}${subject ? `?subject=${encodeURIComponent(subject)}` : ''}`;
---

<a href={href} class:list={['btn px-6 py-3.5 text-lg', variant === 'primary' ? 'btn-primary' : 'btn-ghost']}>
	{label}
</a>
