---
import type { ImageMetadata } from 'astro';

interface Props {
	title: string;
	alt: string;
	image: ImageMetadata;
	darkOverlay?: boolean | undefined;
}

const { title, image, darkOverlay } = Astro.props;
---

<section
	class="relative flex h-[42vh] w-full flex-col items-center justify-end overflow-hidden border-b-2 border-ink bg-cover bg-center bg-no-repeat text-center"
	style={{
		backgroundImage: `linear-gradient(to top, rgba(20,16,10,0.85) 0%, rgba(20,16,10,0.15) 60%, rgba(20,16,10,0.05) 100%), url(${image.src})`,
	}}
	role="img"
	aria-label={title}
>
	<div class="relative z-10 mx-auto w-full max-w-4xl px-6 pb-8">
		<h1 class="font-display text-5xl leading-none font-extrabold tracking-tight text-white md:text-7xl">
			{title}
		</h1>
	</div>
</section>
