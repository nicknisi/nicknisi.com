---
import { Icon } from 'astro-icon/components';
---

<button
	type="button"
	id="themeToggle"
	class="rounded-lg p-2 text-gray-600 transition-colors hover:bg-gray-100 hover:text-purple-700 dark:text-gray-300 dark:hover:bg-dark-surface dark:hover:text-purple-300"
>
	<Icon name="mdi:theme-light-dark" class="h-5 w-5" />
</button>

<script is:inline>
	function getTheme() {
		if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
			return localStorage.getItem('theme');
		}
		if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
			return 'dark';
		}
		return 'light';
	}

	function setTheme(theme = getTheme()) {
		if (theme === 'light') {
			document.documentElement.classList.remove('dark');
		} else {
			document.documentElement.classList.add('dark');
		}
		window.localStorage.setItem('theme', theme);
	}

	function toggleTheme() {
		const theme = getTheme() === 'light' ? 'dark' : 'light';
		setTheme(theme);
	}

	// Set theme immediately (before paint)
	setTheme();

	// Re-attach listener on every page load (View Transitions re-execute scripts)
	document.addEventListener('astro:page-load', () => {
		const button = document.querySelector('button#themeToggle');
		if (button) {
			button.addEventListener('click', toggleTheme);
		}
	});

	// Also handle initial load (first page, no View Transition)
	const button = document.querySelector('button#themeToggle');
	if (button) {
		button.addEventListener('click', toggleTheme);
	}
</script>
