---
interface Props {
	class?: string;
}

const { class: className } = Astro.props;
const classes = ['not-prose grid grid-cols-2 gap-4 my-6', className].join(' ');
---

<div class={classes}>
	<slot />
</div>

<style>
	div :global(img) {
		border-radius: 0.5rem;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
</style>
