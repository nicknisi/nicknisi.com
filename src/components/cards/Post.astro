---
import FormattedDate from '@/components/FormattedDate.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
	post: CollectionEntry<'posts'>;
	hideImage?: boolean | undefined;
	featured?: boolean | undefined;
}

const { post } = Astro.props;
const href = post.data.external ?? `/posts/${post.slug}`;

// Band color is derived from the active accent: tomato and grape both rebind
// with the accent switcher, so the whole grid recolors when the accent
// changes. Deterministic per post so the two-tone rhythm is stable.
const bandClasses = ['bg-tomato', 'bg-grape'] as const;
const tag = post.data.tags?.[0];
const key = (tag ?? post.slug) ?? '';
const band = bandClasses[[...key].reduce((a, c) => a + c.charCodeAt(0), 0) % bandClasses.length];
---

<a
	href={href}
	transition:name={`post-${post.slug}`}
	class="tactile group flex flex-col overflow-hidden rounded-[14px] border-2 border-ink bg-card no-underline shadow-hard-sm"
>
	<span class:list={['block h-3 border-b-2 border-ink', band]}></span>

	<span class="flex flex-1 flex-col gap-2.5 p-5">
		<span class="flex items-center gap-2 font-mono text-xs tracking-wide text-ink-soft uppercase">
			{tag ?? 'writing'}
			{post.data.external && <span class="text-ink-faint">· external ↗</span>}
		</span>

		<h3 class="font-display text-xl leading-snug font-bold text-ink decoration-tomato decoration-2 underline-offset-4 group-hover:underline">
			{post.data.title}
		</h3>

		{post.data.description && <p class="line-clamp-3 text-sm text-ink-soft">{post.data.description}</p>}

		<span class="mt-auto pt-1 font-mono text-xs text-ink-faint">
			<FormattedDate date={post.data.pubDate} />
		</span>
	</span>
</a>
