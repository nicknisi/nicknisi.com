---
import { getPosts } from '@/utils/common';
import Post from '@/components/cards/Post.astro';

interface Props {
	hideImages?: boolean;
	limit?: number | undefined;
	tag?: string | undefined;
	featuredFirst?: boolean | undefined;
	list?: boolean | undefined;
}

const { limit, tag } = Astro.props;
let posts = await getPosts(tag ? undefined : limit);

if (tag) {
	posts = posts.filter(post => post.data.tags?.includes(tag)).slice(0, limit);
}

const isTruncated = limit !== undefined || !!tag;
---

<div class="fade-up-grid grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
	{posts.map(post => <Post post={post} />)}
</div>

{
	isTruncated && (
		<div class="mt-8 flex justify-center">
			<a href="/posts" class="btn btn-ghost">All posts →</a>
		</div>
	)
}
