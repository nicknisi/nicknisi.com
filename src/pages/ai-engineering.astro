---
import BaseLayout from '../layouts/Base.astro';
import Section from '@/components/landing/Section.astro';
import CTA from '@/components/landing/CTA.astro';
import StatCard from '@/components/landing/StatCard.astro';
import PricingCalculator from '@/components/landing/PricingCalculator';
import { Icon } from 'astro-icon/components';
import { getAsset } from '@/utils/image';
import { Image } from 'astro:assets';
import metadata from '../data/metadata.json';

// Typed Void is the authoritative home for this offer; point the canonical there
// once that page is live (flip metadata.trainingCanonical.active). Until then we
// keep the self-referential canonical so we never point at a 404.
const trainingCanonical = metadata.trainingCanonical.active ? metadata.trainingCanonical.url : undefined;

const profileImage = await getAsset('profile.jpg');
const email = 'nick@nisi.org';
const subject = 'AI-Native Training Inquiry';
const bookingUrl = 'https://calendly.com/nicknisi/ai-engineer';

const modules = [
	{
		n: 1,
		icon: 'mdi:swap-horizontal',
		accent: 'tomato',
		title: 'The Mindset Shift',
		blurb:
			'Where is your team today? We start with an honest self-assessment, then show, with a live side-by-side demo, what changes when you stop typing and start directing.',
		points: [
			'The 5 Levels of AI Coding: give your team a shared vocabulary',
			'Why experienced engineers have an advantage, not a disadvantage',
			'The J-curve: why bolting AI onto old workflows makes you slower first',
			'For leaders: spec quality is the new bottleneck, not implementation speed',
		],
	},
	{
		n: 2,
		icon: 'mdi:text-box-search-outline',
		accent: 'grape',
		title: 'Context Engineering',
		blurb:
			'Agents are only as smart as the environment they operate in. Your team learns to optimize their codebase for machines, not just humans, and audits their own repo live.',
		points: [
			'The right amount of context: not more, not less',
			'Pull tribal knowledge out of Slack and into structured files',
			'Agent instructions that actually work (and the antipatterns that don’t)',
			'Ruthless consistency: agents magnify every inconsistency in your codebase',
		],
	},
	{
		n: 3,
		icon: 'mdi:rocket-launch-outline',
		accent: 'sky',
		title: 'Build It Live',
		blurb:
			'The centerpiece of the workshop. We pick a real problem and build it start to finish using agentic workflows. Not slides about best practices. Actual code, actual shipping.',
		points: [
			'Direct, iterate, and course-correct in real time',
			'Everyone codes along with their own tools (Claude Code, Cursor, Copilot, etc.)',
			'Build agent tooling that removes friction so the agent is faster next time',
			'See what "fast" actually looks like when you’re working with agents',
		],
	},
	{
		n: 4,
		icon: 'mdi:check-decagram-outline',
		accent: 'pine',
		title: 'Review, Validate, Ship',
		blurb:
			'Reading code is the job now. Your team learns to build automated trust: mechanical guardrails, self-validating agents, and a testing paradigm shift that changes how you think about quality.',
		points: [
			'Code review patterns for AI-generated code',
			'Enforce architecture mechanically with linters and structural tests',
			'Agents that validate their own work before you ever look',
			'Scenarios vs. Tests: why external specs beat internal test suites when AI writes both',
		],
	},
	{
		n: 5,
		icon: 'mdi:source-branch',
		accent: 'marigold',
		title: 'Working at Scale',
		blurb:
			'How to work differently starting Monday. Run parallel workstreams, build compound returns into your codebase, and keep AI-generated code from turning into unmaintainable slop.',
		points: [
			'Running multiple agents on different tasks simultaneously',
			'Compound engineering: every automation makes the agent faster tomorrow',
			'Entropy management: background validation that catches drift early',
			'The generalist advantage: systems thinking matters at every experience level',
		],
	},
] as const;

const accentBlock: Record<string, string> = {
	tomato: 'bg-tomato text-paper',
	grape: 'bg-grape text-paper',
	sky: 'bg-sky text-ink',
	pine: 'bg-pine text-ink',
	marigold: 'bg-marigold text-ink',
};
const accentText: Record<string, string> = {
	tomato: 'text-tomato',
	grape: 'text-grape',
	sky: 'text-sky',
	pine: 'text-pine',
	marigold: 'text-ink',
};
// Explicit dot fills so Tailwind's static scanner keeps these utilities.
const accentDot: Record<string, string> = {
	tomato: 'bg-tomato',
	grape: 'bg-grape',
	sky: 'bg-sky',
	pine: 'bg-pine',
	marigold: 'bg-marigold',
};

const timeline = [
	{
		label: 'First 30 Days',
		accent: 'tomato',
		body: 'Team adopts new workflows. You see AI usage shift from autocomplete to agentic coding. PR velocity starts climbing.',
	},
	{
		label: '60 Days',
		accent: 'sky',
		body: 'Engineers are self-sufficient with AI tools. Internal conventions are established. The team has a shared language for how they work with AI.',
	},
	{
		label: '90 Days',
		accent: 'pine',
		body: 'Shipping velocity is measurably higher. Engineers are tackling projects they would’ve deprioritized before. The team wonders how they worked without this.',
	},
] as const;

const addons = [
	{
		icon: 'mdi:magnify',
		title: 'Tool Selection & Evaluation',
		body: 'Cutting through the noise. Which tools actually work, which are hype, and how to evaluate them for your stack.',
	},
	{
		icon: 'mdi:shield-check-outline',
		title: 'Internal Conventions & Guardrails',
		body: 'Setting team standards for AI usage. Style guides, review policies, quality gates.',
	},
	{
		icon: 'mdi:puzzle-outline',
		title: 'Something Else Entirely',
		body: 'Have a specific challenge? We’ll scope a custom module together on the intro call.',
	},
] as const;

const howItWorks = [
	{
		icon: 'mdi:account-group-outline',
		accent: 'tomato',
		title: 'Live, Not Pre-Recorded',
		body: 'Real-time instruction with Q&A and pair programming. Remote or on-site, whatever works for your team.',
	},
	{
		icon: 'mdi:cog-outline',
		accent: 'sky',
		title: 'Your Stack, Your Problems',
		body: 'I adapt the curriculum to your languages, frameworks, and the projects you’re actually working on.',
	},
	{
		icon: 'mdi:calendar-check-outline',
		accent: 'pine',
		title: 'Flexible Format',
		body: 'One intensive day, a series of sessions over a week, or something in between. We scope it on the intro call.',
	},
] as const;

const deliverables = [
	{
		icon: 'mdi:file-document-outline',
		title: 'AI Workflow Playbook',
		body: 'A written guide covering the workflows, patterns, and prompts covered in training, tailored to your stack.',
	},
	{
		icon: 'mdi:code-braces',
		title: 'Working Examples',
		body: 'The code your team built during the live session. Real examples to reference, not throwaway demos.',
	},
	{
		icon: 'mdi:clipboard-check-outline',
		title: 'Team Conventions Template',
		body: 'A starting point for internal AI usage guidelines: review standards, quality gates, and tool recommendations.',
	},
	{
		icon: 'mdi:video-outline',
		title: 'Session Recording',
		body: 'Full recording of the training for team members who couldn’t attend or anyone who wants a refresher.',
	},
	{
		icon: 'mdi:calendar-refresh-outline',
		title: 'Optional Follow-Up Session',
		body: '30-60 days after training, we regroup. Address new questions, reinforce what stuck, and troubleshoot what didn’t.',
	},
] as const;

const faqs = [
	{
		q: 'What makes this different from AI/ML courses?',
		a: 'We don’t build AI models. We teach engineers how to use AI to ship software faster. No RAG pipelines, no fine-tuning. Just practical workflows you’ll use on Monday.',
	},
	{
		q: 'How long is the training?',
		a: 'Depends on your team. Could be a day, could be a week. We figure out the right scope together on the intro call.',
	},
	{
		q: 'What’s the ideal team size?',
		a: '3-15 engineers. Small enough that everyone gets hands-on time, big enough for good discussion.',
	},
	{
		q: 'Do we need AI experience?',
		a: 'Nope. You need to be a solid engineer. That’s the prerequisite. We handle the AI part.',
	},
	{
		q: 'What tools do you cover?',
		a: 'Claude Code, Claude Desktop, Cursor, GitHub Copilot, and others. Every team’s toolset is different, so we’ll focus on what your company already has access to and what makes sense for your stack.',
	},
	{
		q: 'Can we customize the curriculum?',
		a: 'That’s the whole idea. The five core modules are the baseline. We go deeper wherever your team needs it.',
	},
] as const;
---

<BaseLayout
	title="The AI-Native Engineer | Nick Nisi"
	description="Live training that teaches engineering teams to ship faster with AI. Not a course on building AI. A course on being a better engineer with it."
	headerImage="/ai-engineering-og.png"
	canonical={trainingCanonical}
	fullWidth
>
	{/* Section 1: Hero */}
	<Section variant="hero">
		<div class="grid items-center gap-10 md:grid-cols-[1.5fr_1fr] md:gap-14">
			<div>
				<span class="sticker -rotate-2"><span class="sticker-dot bg-tomato"></span>Live team training</span>

				<h1 class="mt-5 text-5xl leading-[0.95] font-extrabold tracking-tight md:text-7xl">
					The AI-Native
					<span class="relative inline-block text-tomato">
						Engineer
						<svg class="absolute -bottom-2 left-0 h-3 w-full overflow-visible" viewBox="0 0 200 18" fill="none" aria-hidden="true">
							<path d="M3 12 C 50 6, 90 14, 130 9 S 188 6, 197 10" stroke="currentColor" stroke-width="5" stroke-linecap="round"></path>
						</svg>
					</span>
				</h1>

				<p class="mt-6 max-w-[24ch] font-display text-2xl leading-snug font-bold text-ink md:text-3xl">
					You're not being replaced. You're being promoted.
				</p>

				<p class="mt-4 max-w-[52ch] text-lg text-ink-soft">
					Live training that turns strong engineers into better ones. Your team learns to ship faster with AI, not get
					replaced by it.
				</p>

				<div class="mt-9 flex flex-col gap-4 sm:flex-row sm:flex-wrap">
					<CTA href={bookingUrl} label="Book a Call" />
					<CTA email={email} subject={subject} label="Or Email Me" variant="secondary" />
				</div>
			</div>

			<div class="justify-self-center md:justify-self-end">
				<div class="panel grid gap-3 rotate-2 p-6 shadow-hard-lg">
					<div class="flex flex-wrap gap-2">
						<span class="sticker -rotate-3"><span class="sticker-dot bg-marigold"></span>Hands-on</span>
						<span class="sticker rotate-2"><span class="sticker-dot bg-sky"></span>Your codebase</span>
					</div>
					<p class="max-w-[26ch] font-display text-lg leading-snug font-bold text-ink">
						Stop typing. Start directing. Watch what your team can actually ship.
					</p>
					<p class="font-mono text-xs text-ink-soft">// remote or on-site · 3-15 engineers</p>
				</div>
			</div>
		</div>
	</Section>

	{/* Section 2: The Problem */}
	<Section variant="muted" narrow>
		<span class="sticker -rotate-1"><span class="sticker-dot bg-tomato"></span>The problem</span>
		<h2 class="mt-4 text-3xl font-extrabold md:text-4xl">Your Team Has AI Tools. Now What?</h2>
		<div class="mt-6 space-y-4 text-lg text-ink-soft">
			<p>
				Leadership bought the licenses. Everyone has Copilot. Maybe someone tried Cursor. But research shows experienced
				developers are actually <strong class="text-ink">19% slower</strong> when they bolt AI onto existing workflows, while
				<em>believing</em> they got 24% faster. The gap between "we have AI tools" and shipping faster with them is bigger
				than anyone wants to admit.
			</p>
			<p>
				That's the J-curve. Adding AI to old workflows makes you worse before it makes you better. The breakthrough doesn't
				come from better tools. It comes from redesigning how your team works.
			</p>
		</div>
	</Section>

	{/* Section 3: The Reframe */}
	<Section variant="accent">
		<div class="mx-auto max-w-3xl">
			<span class="sticker -rotate-1 bg-paper"><span class="sticker-dot bg-grape"></span>The reframe</span>
			<h2 class="mt-4 text-3xl font-extrabold md:text-4xl">The Job Changed. The Craft Didn't.</h2>
			<div class="mt-6 space-y-4 text-xl leading-relaxed text-ink md:text-2xl">
				<p>
					AI writes the code now. So what do <em>you</em> do? The same things that always mattered: decide what to build,
					design how it fits together, and make sure it actually works. <strong>That's engineering.</strong>
				</p>
				<p>
					The bottleneck isn't implementation speed anymore. It's
					<strong>how precisely you can describe what should exist</strong>. Your ten years of experience? That's the
					advantage. You know what good looks like. That judgment is exactly what AI doesn't have.
				</p>
				<p class="font-display text-lg font-bold">
					Honestly? It's the most fun I've had writing software in years. Your team should be having this much fun too.
				</p>
			</div>
		</div>
	</Section>

	{/* Section 4: Social Proof / Stats */}
	<Section variant="default" class="scroll-reveal">
		<div class="fade-up-grid grid grid-cols-1 gap-6 sm:grid-cols-3">
			<StatCard value="3x" accent="tomato" label="GitHub contributions in one year" />
			<StatCard value="0" accent="sky" label="Lines of code written by hand in 6 months" />
			<StatCard value="20+" accent="pine" label="Repos maintained solo with AI workflows" />
		</div>
		<p class="mx-auto mt-5 max-w-md text-center font-mono text-sm text-ink-soft">
			Output tripled. Quality held. Staff Engineer, still shipping every day.
		</p>
		<p class="mx-auto mt-8 max-w-2xl text-center text-ink-soft">
			I built a production AI agent that configures and ships SDK integrations on its own. I maintained 20+ repos as a solo
			DX engineer using these same workflows. This is how I actually work. I want to show your team how to do it too.
		</p>
	</Section>

	{/* Section 5: Curriculum — Core Modules */}
	<Section variant="muted" class="scroll-reveal">
		<span class="sticker -rotate-1"><span class="sticker-dot bg-grape"></span>Curriculum</span>
		<h2 class="mt-4 text-3xl font-extrabold md:text-4xl">What Your Team Will Learn</h2>
		<p class="mt-4 max-w-2xl text-lg text-ink-soft">
			Five modules that take your team from autocomplete to agentic engineering, tailored to your stack, your tools, and
			your actual codebase.
		</p>
		<div class="fade-up-grid mt-10 space-y-6">
			{
				modules.map((m) => (
					<div class="panel grid gap-5 p-6 md:grid-cols-[auto_1fr] md:p-7">
						<div class="flex items-center gap-4 md:flex-col md:items-start md:gap-3">
							<div
								class:list={[
									'grid h-14 w-14 -rotate-2 place-items-center rounded-[14px] border-2 border-ink font-display text-2xl font-extrabold shadow-hard-sm',
									accentBlock[m.accent],
								]}
							>
								{m.n}
							</div>
							<Icon name={m.icon} class:list={['size-9', accentText[m.accent]]} />
						</div>
						<div>
							<h3 class="font-display text-xl font-bold text-ink">{m.title}</h3>
							<p class="mt-2 text-ink-soft">{m.blurb}</p>
							<ul class="mt-4 space-y-1.5 text-sm text-ink-soft">
								{m.points.map((pt) => (
									<li class="flex gap-2.5">
										<span class:list={['mt-2 inline-block h-1.5 w-1.5 shrink-0 rounded-full', accentDot[m.accent]]} />
										<span>{pt}</span>
									</li>
								))}
							</ul>
						</div>
					</div>
				))
			}
		</div>
	</Section>

	{/* Section 6: For Engineering Leaders */}
	<Section variant="accent" class="scroll-reveal">
		<span class="sticker -rotate-1 bg-paper"><span class="sticker-dot bg-pine"></span>For leaders</span>
		<h2 class="mt-4 text-3xl font-extrabold md:text-4xl">For Engineering Leaders</h2>
		<div class="mt-6 max-w-3xl space-y-4 text-lg text-ink">
			<p>
				You got the mandate: adopt AI. But what does that actually mean for your team? How do you measure it? What does
				"good" look like? This isn't just training for ICs.
			</p>
			<p>
				We cover how to think about AI adoption as a leader: setting expectations, measuring impact, building conventions
				that stick, and knowing what to watch out for.
			</p>
		</div>
		<div class="mt-10 grid grid-cols-1 gap-5 md:grid-cols-3">
			{
				timeline.map((t) => (
					<div class="rounded-[14px] border-2 border-ink bg-paper p-5 shadow-hard-sm">
						<span
							class:list={[
								'inline-flex -rotate-1 items-center rounded-full border-2 border-ink px-3 py-1 font-display text-sm font-bold',
								accentBlock[t.accent],
							]}
						>
							{t.label}
						</span>
						<p class="mt-3 text-sm text-ink-soft">{t.body}</p>
					</div>
				))
			}
		</div>
	</Section>

	{/* Section 7: Customizable Add-ons */}
	<Section variant="default">
		<span class="sticker -rotate-1"><span class="sticker-dot bg-marigold"></span>Add-ons</span>
		<h2 class="mt-4 text-3xl font-extrabold md:text-4xl">Go Deeper Where You Need It</h2>
		<p class="mt-4 max-w-2xl text-lg text-ink-soft">
			Everyone gets the core modules. These are examples of add-ons we've built before, or we can create something new
			based on what your team actually needs.
		</p>
		<div class="mt-10 grid gap-5 md:grid-cols-3">
			{
				addons.map((a) => (
					<div class="panel flex flex-col gap-3 p-6">
						<Icon name={a.icon} class="size-7 text-tomato" />
						<h3 class="font-display text-lg font-bold text-ink">{a.title}</h3>
						<p class="text-sm text-ink-soft">{a.body}</p>
					</div>
				))
			}
		</div>
	</Section>

	{/* Section 9: How It Works */}
	<Section variant="muted">
		<span class="sticker -rotate-1"><span class="sticker-dot bg-sky"></span>How it works</span>
		<h2 class="mt-4 text-3xl font-extrabold md:text-4xl">How It Works</h2>
		<div class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-3">
			{
				howItWorks.map((h) => (
					<div class="rounded-[14px] border-2 border-ink bg-card p-6 shadow-hard-sm">
						<span
							class:list={[
								'grid h-12 w-12 -rotate-3 place-items-center rounded-[12px] border-2 border-ink shadow-hard-sm',
								accentBlock[h.accent],
							]}
						>
							<Icon name={h.icon} class="size-6" />
						</span>
						<h3 class="mt-4 font-display text-xl font-bold text-ink">{h.title}</h3>
						<p class="mt-2 text-ink-soft">{h.body}</p>
					</div>
				))
			}
		</div>
	</Section>

	{/* Section 10: What Your Team Walks Away With */}
	<Section variant="default" class="scroll-reveal">
		<span class="sticker -rotate-1"><span class="sticker-dot bg-pine"></span>Deliverables</span>
		<h2 class="mt-4 text-3xl font-extrabold md:text-4xl">What Your Team Walks Away With</h2>
		<div class="mt-10 grid gap-4 md:grid-cols-2">
			{
				deliverables.map((d) => (
					<div class="flex items-start gap-4 rounded-[14px] border-2 border-ink bg-card p-5 shadow-hard-sm">
						<span class="grid size-10 shrink-0 place-items-center rounded-full border-2 border-ink bg-marigold text-ink">
							<Icon name={d.icon} class="size-5" />
						</span>
						<div>
							<h3 class="font-display text-lg font-bold text-ink">{d.title}</h3>
							<p class="mt-1 text-sm text-ink-soft">{d.body}</p>
						</div>
					</div>
				))
			}
		</div>
	</Section>

	{/* Section 11: Instructor */}
	<Section variant="accent" class="scroll-reveal">
		<div class="grid items-center gap-8 md:grid-cols-[auto_1fr] md:gap-12">
			<div class="w-44 -rotate-2 overflow-hidden rounded-2xl border-2 border-ink bg-paper shadow-hard-lg md:w-52">
				<Image src={profileImage} alt="Nick Nisi" width={256} height={256} quality="max" class="aspect-square h-full w-full object-cover" />
			</div>
			<div>
				<span class="sticker -rotate-1 bg-paper"><span class="sticker-dot bg-tomato"></span>Your instructor</span>
				<h2 class="mt-4 text-3xl font-extrabold md:text-4xl">Meet Your Instructor</h2>
				<p class="mt-4 text-lg text-ink">
					I'm a Staff Engineer. I haven't written a line of code by hand in six months and my output has never been higher.
					I built the WorkOS CLI AI Installer (a production agent that ships SDK integrations on its own), I've given 50+
					conference talks, and I was a host on
					<a href="https://jsparty.fm" class="font-bold underline decoration-ink decoration-2 underline-offset-2">JS Party</a>.
				</p>
				<div class="mt-6 flex flex-wrap gap-2.5">
					<span class="sticker rotate-1 bg-paper"><span class="sticker-dot bg-tomato"></span>50+ Conference Talks</span>
					<span class="sticker -rotate-1 bg-paper"><span class="sticker-dot bg-sky"></span>Staff Engineer</span>
					<span class="sticker rotate-1 bg-paper"><span class="sticker-dot bg-grape"></span>JS Party Alum</span>
					<span class="sticker -rotate-1 bg-paper"><span class="sticker-dot bg-pine"></span>Open Source</span>
				</div>
				<p class="mt-5">
					<a href="/about" class="font-display font-bold text-ink underline decoration-ink decoration-2 underline-offset-4">Full bio →</a>
				</p>
			</div>
		</div>
	</Section>

	{/* Section 12: Who It's For */}
	<Section variant="muted">
		<span class="sticker -rotate-1"><span class="sticker-dot bg-grape"></span>Fit check</span>
		<h2 class="mt-4 text-3xl font-extrabold md:text-4xl">Is This Right for Your Team?</h2>
		<div class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-2">
			<div class="rounded-[14px] border-2 border-ink bg-card p-6 shadow-hard-sm">
				<span class="inline-flex items-center gap-2 rounded-full border-2 border-ink bg-pine px-3 py-1 font-display text-sm font-bold text-ink">
					<Icon name="mdi:check-bold" class="size-4" /> Great Fit
				</span>
				<ul class="mt-4 space-y-2.5 text-ink-soft">
					<li class="flex gap-2.5"><Icon name="mdi:check" class="mt-1 size-4 shrink-0 text-pine" /><span>Teams of 3-50 engineers shipping a product</span></li>
					<li class="flex gap-2.5"><Icon name="mdi:check" class="mt-1 size-4 shrink-0 text-pine" /><span>Organizations where leadership said "use AI" but nobody explained how</span></li>
					<li class="flex gap-2.5"><Icon name="mdi:check" class="mt-1 size-4 shrink-0 text-pine" /><span>Engineers using Copilot for autocomplete but not much else</span></li>
					<li class="flex gap-2.5"><Icon name="mdi:check" class="mt-1 size-4 shrink-0 text-pine" /><span>Eng managers who need to measure and report on AI adoption</span></li>
				</ul>
			</div>
			<div class="rounded-[14px] border-2 border-ink bg-card p-6 shadow-hard-sm">
				<span class="inline-flex items-center gap-2 rounded-full border-2 border-ink bg-tomato px-3 py-1 font-display text-sm font-bold text-paper">
					<Icon name="mdi:close-thick" class="size-4" /> Not a Fit
				</span>
				<ul class="mt-4 space-y-2.5 text-ink-soft">
					<li class="flex gap-2.5"><Icon name="mdi:close" class="mt-1 size-4 shrink-0 text-tomato" /><span>Looking for a course on building AI/ML models or agents</span></li>
					<li class="flex gap-2.5"><Icon name="mdi:close" class="mt-1 size-4 shrink-0 text-tomato" /><span>Non-technical teams or individuals looking for 1:1 coaching</span></li>
					<li class="flex gap-2.5"><Icon name="mdi:close" class="mt-1 size-4 shrink-0 text-tomato" /><span>Teams already shipping with agentic workflows daily</span></li>
				</ul>
			</div>
		</div>
	</Section>

	{/* Section 13: Pricing Calculator */}
	<Section id="pricing" variant="dark">
		<PricingCalculator client:only="react" bookingUrl={bookingUrl} email={email} />
	</Section>

	{/* Section 14: FAQ */}
	<Section variant="muted" narrow>
		<span class="sticker -rotate-1"><span class="sticker-dot bg-sky"></span>FAQ</span>
		<h2 class="mt-4 text-3xl font-extrabold md:text-4xl">Common Questions</h2>
		<div class="mt-10 space-y-3">
			{
				faqs.map((f) => (
					<details class="group rounded-[14px] border-2 border-ink bg-card p-5 shadow-hard-sm">
						<summary class="flex cursor-pointer items-center justify-between gap-3 font-display text-lg font-bold text-ink">
							<span>{f.q}</span>
							<Icon name="mdi:chevron-down" class="size-5 shrink-0 text-tomato transition-transform duration-200 group-open:rotate-180" />
						</summary>
						<p class="mt-4 leading-relaxed text-ink-soft">{f.a}</p>
					</details>
				))
			}
			<details class="group rounded-[14px] border-2 border-ink bg-card p-5 shadow-hard-sm">
				<summary class="flex cursor-pointer items-center justify-between gap-3 font-display text-lg font-bold text-ink">
					<span>What's the investment?</span>
					<Icon name="mdi:chevron-down" class="size-5 shrink-0 text-tomato transition-transform duration-200 group-open:rotate-180" />
				</summary>
				<p class="mt-4 leading-relaxed text-ink-soft">
					There's a
					<a href="#pricing" class="font-bold text-ink underline decoration-tomato decoration-2 underline-offset-2">pricing calculator</a>
					on this page for a ballpark. Exact numbers depend on team size and what we cover. Let's talk about it on a call.
				</p>
			</details>
		</div>
	</Section>

	{/* Section 15: Final CTA */}
	<Section variant="dark" class="text-center">
		<span class="sticker -rotate-2"><span class="sticker-dot bg-marigold"></span>Let's talk</span>
		<h2 class="mt-5 text-3xl font-extrabold text-paper md:text-5xl">Let's Talk About Your Team</h2>
		<p class="mx-auto mt-4 max-w-xl text-lg text-paper/80">
			30 minutes. No pitch deck. We'll figure out if this is a good fit and what your team actually needs.
		</p>
		<div class="mt-9 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
			<CTA href={bookingUrl} label="Book a Call" />
			<CTA email={email} subject={subject} label="Or Email Me" variant="secondary" />
		</div>
	</Section>
</BaseLayout>
