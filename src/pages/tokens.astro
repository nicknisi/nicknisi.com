---
import BaseLayout from '@/layouts/Base.astro';
import { getEntry } from 'astro:content';
import StaleBadge from '@/components/tokenmaxing/StaleBadge.astro';
import MobyDickFooter from '@/components/tokenmaxing/MobyDickFooter.astro';
import Dashboard from '@/components/tokenmaxing/Dashboard.tsx';
import WeeklyHighlights from '@/components/tokenmaxing/WeeklyHighlights.astro';

const entry = await getEntry('tokenmaxing', 'current');
const data = entry?.data;
---

<BaseLayout title="Tokens | Nick Nisi" description="Weekly aggregate of my AI coding-agent usage and public PRs.">
	<section class="mx-auto max-w-6xl px-6 py-12">
		<header class="mb-8">
			<h1 class="font-serif text-4xl font-bold tracking-tight md:text-5xl">Tokenmaxing</h1>
			{
				data ? (
					<p class="mt-3 text-gray-600 dark:text-gray-400">
						{data.period.from} → {data.period.to} · last updated{' '}
						<time datetime={data.generatedAt}>
							{new Date(data.generatedAt).toLocaleDateString('en-US', { dateStyle: 'medium' })}
						</time>{' '}
						<StaleBadge generatedAt={data.generatedAt} />
					</p>
				) : (
					<p class="mt-3 text-gray-600 dark:text-gray-400">Data feed offline — refreshes weekly.</p>
				)
			}
		</header>

		<p class="mb-12 max-w-3xl text-lg leading-relaxed text-gray-600 dark:text-gray-300">
			A running snapshot of how I use AI coding agents — Claude Code, Codex, Pi. Tokens spent, sessions logged, public
			PRs shipped. Built to make my own habits visible to me; left public because nothing here is interesting enough to
			hide. Updated weekly from local agent logs aggregated on my laptop and pushed to a gist; the page rebuilds
			automatically when fresh data lands.
		</p>

		{
			data && (
				<>
					<Dashboard
						client:load
						daily={data.daily}
						breakdown={{
							byTool: data.byTool,
							byProvider: data.byProvider,
							byModel: data.byModel,
							byProject: data.byProject,
						}}
						staticSummary={{
							currentStreakDays: data.summary.currentStreakDays,
							longestStreakDays: data.summary.longestStreakDays,
						}}
					/>
					<WeeklyHighlights weeks={data.weeklyHighlights} />
					<MobyDickFooter totalTokens={data.summary.totalTokens} />
				</>
			)
		}
	</section>
</BaseLayout>
