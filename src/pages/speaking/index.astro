---
import PageLayout from '@/layouts/Page.astro';
import Callout from '@/components/Callout.astro';
import Appearances from '@/components/sections/Appearances.astro';
import metadata from '@/data/metadata.json';
---

<PageLayout title="Speaking">
	<p class="mb-10 max-w-[60ch] font-display text-xl leading-snug font-bold text-ink md:text-2xl">
		Technical insights and engaging conversations for conferences, meetups, podcasts, and industry events. Spanning
		technical presentations, panel moderation, and event hosting.
	</p>

	<Appearances limit={9} />

	<div class="mt-16 mb-8 flex justify-center">
		<Callout title="Fun fact" variant="info">
			<p>
				Beyond tech conferences, I've had the honor of officiating <span class="font-bold"
					>{metadata.officiantCount} weddings</span
				>, bringing the same dedication to creating meaningful moments in people's lives.
			</p>
		</Callout>
	</div>

	<section class="mt-12">
		<div class="rounded-2xl border-2 border-ink bg-marigold p-6 shadow-hard md:p-8">
			<h2 class="mt-0 mb-3 font-display text-2xl font-extrabold text-ink md:text-3xl">Want me at your event?</h2>
			<p class="m-0 max-w-[56ch] font-display text-lg font-bold text-ink">
				I'm always interested in new speaking opportunities. Whether it's a conference talk, panel moderation, or event
				hosting, let's discuss how I can contribute to making your event successful.{' '}
				<a href="/about" class="whitespace-nowrap underline decoration-ink decoration-2 underline-offset-4">say hi →</a>
			</p>
		</div>
	</section>
</PageLayout>
