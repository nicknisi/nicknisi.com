---
import BaseLayout from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';
import { getAsset, getThumbnail } from '@/utils/image.js';
import { getAppearances, toReadableDate } from '@/utils/common';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import Callout from '@/components/Callout.astro';
import CopyableContent from '@/components/CopyableContent.astro';
import FormattedDate from '@/components/FormattedDate.astro';
import metadata from '@/data/metadata.json';

const profileImg = await getAsset(metadata.profile);
const appearances = (await getAppearances()).filter(a => a.data.promote);
const projects = (await getCollection('projects', p => p.data.promote)).sort(
	(a, b) => new Date(b.data.startDate).getTime() - new Date(a.data.startDate).getTime(),
);
const socials = Object.entries(metadata.social).filter(([, { hidden }]) => !hidden);

// Pre-resolve thumbnails for each talk
const talkThumbnails = new Map<string, string | import('astro').ImageMetadata>();
await Promise.all(
	appearances.map(async talk => {
		talkThumbnails.set(talk.id, await getThumbnail(talk.data));
	}),
);

const talkTypeStyles = {
	'Conference Talk': { icon: 'mdi:presentation-play', bg: 'bg-vivid-light-blue-100 dark:bg-vivid-light-blue-900/20', text: 'text-vivid-light-blue-700 dark:text-vivid-light-blue-300' },
	Panel: { icon: 'mdi:forum', bg: 'bg-teal-100 dark:bg-teal-900/20', text: 'text-teal-800 dark:text-teal-300' },
	Workshop: { icon: 'mdi:hammer-wrench', bg: 'bg-yellow-100 dark:bg-yellow-900/20', text: 'text-yellow-800 dark:text-yellow-300' },
	Keynote: { icon: 'mdi:star', bg: 'bg-vivid-pink-100 dark:bg-vivid-pink-900/20', text: 'text-vivid-pink-800 dark:text-vivid-pink-300' },
	'Lightning Talk': { icon: 'mdi:flash', bg: 'bg-purple-100 dark:bg-purple-900/20', text: 'text-purple-700 dark:text-purple-300' },
	Podcast: { icon: 'mdi:microphone', bg: 'bg-vivid-yellow-100 dark:bg-vivid-yellow-900/20', text: 'text-vivid-yellow-700 dark:text-vivid-yellow-300' },
	Moderation: { icon: 'mdi:forum', bg: 'bg-vivid-pink-100 dark:bg-vivid-pink-900/20', text: 'text-vivid-pink-700 dark:text-vivid-pink-300' },
} as const;
---

<BaseLayout
	title="About Nick Nisi"
	description="Learn more about Nick Nisi, a developer experience engineer, podcast host, and conference speaker."
	fullWidth
>
	<!-- Hero -->
	<section class="relative overflow-hidden bg-gray-50 dark:bg-dark-arsenic">
		<div class="absolute inset-0 overflow-hidden">
			<div class="absolute top-[-20%] left-[10%] h-[500px] w-[500px] rounded-full bg-purple-200/20 blur-3xl dark:bg-purple-700/10"></div>
			<div class="absolute bottom-[-10%] right-[15%] h-[400px] w-[400px] rounded-full bg-teal-200/20 blur-3xl dark:bg-teal-700/10"></div>
		</div>

		<div class="relative z-10 mx-auto flex max-w-5xl flex-col items-center px-6 pt-16 pb-12 md:pt-24 md:pb-16">
			<div class="gradient-border rounded-full p-1">
				<Image
					src={profileImg}
					alt="Nick Nisi"
					width={512}
					height={512}
					quality="max"
					class="h-40 w-40 rounded-full object-cover md:h-56 md:w-56"
				/>
			</div>

			<h1 class="gradient-text mt-8 text-center font-serif text-5xl font-bold tracking-tight md:text-7xl">
				Nick Nisi
			</h1>

			<p class="mt-4 text-center text-xl text-blue-gray-600 dark:text-gray-300 md:text-2xl">
				Staff Engineer · TypeScript · Developer Experience
			</p>

			<!-- Social proof chips -->
			<div class="mt-6 flex flex-wrap justify-center gap-3">
				{["DX Engineer", "50+ Conference Talks", "NebraskaJS Organizer"].map(label => (
					<span class="rounded-full border border-gray-200 bg-white/80 px-4 py-1.5 text-sm font-medium text-gray-700 dark:border-dark-border dark:bg-dark-surface/80 dark:text-gray-300">
						{label}
					</span>
				))}
			</div>
		</div>

		<div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-b from-transparent to-white dark:to-dark-arsenic"></div>
	</section>

	<!-- Story -->
	<section class="scroll-reveal bg-white px-6 pt-16 pb-12 dark:bg-dark-arsenic">
		<div class="mx-auto max-w-3xl">
			<div class="prose prose-lg dark:prose-invert">
				<p>
					Hi! I'm Nick Nisi — dad of two, husband, and Developer Experience Engineer at <a href="https://workos.com">WorkOS</a>.
				</p>
				<p>
					You might know me from co-hosting the <a href="https://jsparty.fm">JS Party</a> podcast, or from organizing <a href="https://nejsconf.com">NEJS Conf</a> and <a href="https://archive.tsconf.io/2021/">TypeScript Conf</a>. These days I run the <a href="https://nebraskajs.com">NebraskaJS</a> meetup and focus on developer tooling and TypeScript.
				</p>
				<p>
					Outside of tech, I've officiated {metadata.officiantCount} weddings — turns out "conference emcee" translates surprisingly well to "wedding officiant."
				</p>
				<p>
					Connect with me on <a href="https://bsky.app/profile/nicknisi.com">Bluesky</a>, <a href="https://github.com/nicknisi">GitHub</a>, or <a href="https://linkedin.com/in/nicknisi">LinkedIn</a>. Response times may vary.
				</p>
			</div>

			<div class="mt-8">
				<Callout title="Looking for my resume?">
					<p>
						You can find it at <a href="/resume">nicknisi.com/resume</a>.
					</p>
				</Callout>
			</div>
		</div>
	</section>

	<!-- Speaking -->
	<section class="scroll-reveal bg-gray-50 px-6 py-16 dark:bg-dark-surface/30">
		<div class="mx-auto max-w-5xl">
			<h2 class="gradient-text mb-10 text-center font-serif text-3xl font-bold md:text-4xl">Speaking</h2>
			<div class="fade-up-grid grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
				{appearances.map(talk => {
					const firstInstance = talk.data.instances[0]!;
					const hasMultiple = talk.data.instances.length > 1;
					const href = talk.data.detailsUrl || (hasMultiple ? `/speaking/${talk.slug}` : firstInstance.url);
					const style = talkTypeStyles[talk.data.type as keyof typeof talkTypeStyles];
					const thumbnail = talkThumbnails.get(talk.id)!;
					return (
						<a
							href={href}
							class="hover-glow group relative flex flex-col overflow-hidden rounded-xl border border-gray-100 bg-white no-underline transition-all dark:border-dark-border dark:bg-dark-surface"
						>
							{/* Thumbnail */}
							<div class="h-[180px] w-full overflow-hidden bg-gray-100 dark:bg-dark-surface-elevated">
								{typeof thumbnail === 'string' ? (
									<img src={thumbnail} alt={talk.data.title} class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy" />
								) : (
									<Image src={thumbnail} alt={talk.data.title} width={320} height={180} class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" />
								)}
							</div>
							<div class="flex flex-1 flex-col p-4">
								{/* Type badge */}
								<div class="mb-3 flex items-center gap-2">
									<span class:list={['inline-flex rounded-full p-1.5', style.bg]}>
										<Icon name={style.icon} class:list={['h-4 w-4', style.text]} />
									</span>
									<span class:list={['text-xs font-bold uppercase', style.text]}>
										{talk.data.type}
									</span>
								</div>
								{/* Title */}
								<h3 class="mb-2 p-0 text-base font-semibold text-gray-900 group-hover:text-purple-700 dark:text-white dark:group-hover:text-purple-300">
									{talk.data.title}
								</h3>
								{/* Event & date */}
								<div class="mt-auto flex flex-col gap-1 text-sm text-gray-500 dark:text-gray-400">
									{hasMultiple ? (
										<div class="flex items-center gap-1">
											<Icon name="mdi:star-circle" class="h-4 w-4" />
											<span>{talk.data.instances.length} appearances</span>
										</div>
									) : (
										<>
											<div class="flex items-center gap-1">
												<Icon name="mdi:ticket" class="h-4 w-4" />
												<span>{firstInstance.event}</span>
											</div>
											<div class="flex items-center gap-1">
												<Icon name="mdi:calendar" class="h-4 w-4" />
												<FormattedDate date={new Date(toReadableDate(firstInstance.date))} />
											</div>
										</>
									)}
								</div>
							</div>
						</a>
					);
				})}
			</div>
			<div class="mt-8 flex justify-center">
				<a href="/speaking/all" class="hover-glow gradient-border rounded-xl px-6 py-3 font-semibold text-gray-800 no-underline dark:text-gray-200">
					View all talks →
				</a>
			</div>
		</div>
	</section>

	<!-- Projects -->
	<section class="scroll-reveal bg-white px-6 py-16 dark:bg-dark-arsenic">
		<div class="mx-auto max-w-5xl">
			<h2 class="gradient-text mb-10 text-center font-serif text-3xl font-bold md:text-4xl">Projects</h2>
			<div class="fade-up-grid grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
				{projects.map(project => (
					<a
						href={project.data.url}
						target="_blank"
						class="hover-glow group flex flex-col overflow-hidden rounded-xl border border-gray-100 bg-white no-underline transition-all dark:border-dark-border dark:bg-dark-surface"
					>
						{/* Gradient accent bar */}
						<div class="h-1 bg-gradient-to-r from-purple-400 to-teal-400" />
						<div class="flex flex-1 flex-col p-4">
							<h3 class="mb-2 p-0 text-lg font-semibold text-gray-900 group-hover:text-purple-700 dark:text-white dark:group-hover:text-purple-300">
								{project.data.name}
							</h3>
							{project.data.description && (
								<p class="mb-3 text-sm text-gray-500 dark:text-gray-400">
									{project.data.description}
								</p>
							)}
							<div class="mt-auto flex flex-wrap gap-1.5">
								{project.data.roles.map(role => (
									<span class="rounded-full bg-teal-100 px-2.5 py-0.5 text-xs font-semibold text-teal-700 dark:bg-teal-900/30 dark:text-teal-300">
										{role}
									</span>
								))}
								{project.data.status === 'inactive' && (
									<span class="rounded-full bg-red-100 px-2.5 py-0.5 text-xs font-semibold text-red-700 dark:bg-red-900/30 dark:text-red-300">
										inactive
									</span>
								)}
							</div>
						</div>
					</a>
				))}
			</div>
		</div>
	</section>

	<!-- Press Kit / Bio -->
	<section class="scroll-reveal bg-gray-50 px-6 py-16 dark:bg-dark-surface/30">
		<div class="mx-auto max-w-3xl">
			<h2 class="gradient-text mb-8 font-serif text-3xl font-bold md:text-4xl">Press Kit</h2>
			<p class="mb-6 text-gray-600 dark:text-gray-400">
				Here are a few different versions of my bio that you can use.
			</p>

			<h3 class="mb-3 text-lg font-semibold text-gray-900 dark:text-gray-100">First Person Bio</h3>
			<CopyableContent padding border>
				<p>
					Hey, I'm Nick! I'm a Developer Experience Engineer at <a href="https://workos.com">WorkOS</a>, where I focus on creating tools and experiences that make life easier for developers building for the modern web. I'm a long-time TypeScript enthusiast and community builder — I've organized conferences like <a href="https://nejsconf.com">NEJS Conf</a> and <a href="https://archive.tsconf.io">TypeScript Conf</a>, emcee'd more than ten events, and taught JavaScript and TypeScript workshops for years.
				</p>
				<p>
					Previously, I co-hosted the <a href="https://changelog.com/jsparty">JS Party</a> podcast, chatting about all things JavaScript and web development. These days, I'm focused on developer productivity, open source, and helping teams build with confidence — and maybe still sneaking in a few conference talks along the way.
				</p>
			</CopyableContent>

			<h3 class="mt-8 mb-3 text-lg font-semibold text-gray-900 dark:text-gray-100">Third Person Bio</h3>
			<CopyableContent padding border>
				<p>
					Nick Nisi is a Developer Experience Engineer at <a href="https://workos.com">WorkOS</a>, where he helps developers build faster and smarter for the modern web. A long-time TypeScript advocate, Nick has organized events like <a href="https://nejsconf.com">NEJS Conf</a> and <a href="https://archive.tsconf.io">TypeScript Conf</a>, emcee'd more than a dozen conferences, and taught JavaScript workshops for years. He previously co-hosted the <a href="https://changelog.com/jsparty">JS Party</a> podcast and continues to share his passion for developer experience, open source, and the craft of building great software.
				</p>
			</CopyableContent>
		</div>
	</section>

	<!-- Connect -->
	<section class="scroll-reveal relative overflow-hidden bg-white px-6 py-16 dark:bg-dark-arsenic">
		{/* Subtle background blobs */}
		<div class="absolute inset-0 overflow-hidden">
			<div class="absolute top-[-10%] right-[20%] h-[300px] w-[300px] rounded-full bg-purple-200/10 blur-3xl dark:bg-purple-700/5"></div>
			<div class="absolute bottom-[-10%] left-[10%] h-[250px] w-[250px] rounded-full bg-teal-200/10 blur-3xl dark:bg-teal-700/5"></div>
		</div>
		<div class="relative z-10 mx-auto max-w-3xl">
			<h2 class="gradient-text mb-10 text-center font-serif text-3xl font-bold md:text-4xl">Connect</h2>
			<div class="fade-up-grid flex flex-wrap justify-center gap-4">
				{socials.map(([name, { url }]) => (
					<a
						href={url}
						target="_blank"
						class="hover-glow flex items-center gap-3 rounded-xl border border-gray-200 bg-white px-6 py-4 font-medium text-gray-700 no-underline transition-all hover:border-purple-300 dark:border-dark-border dark:bg-dark-surface dark:text-gray-300 dark:hover:border-purple-600"
					>
						<Icon name={`simple-icons:${name}`} class="h-6 w-6" />
						<span class="capitalize">{name}</span>
					</a>
				))}
			</div>
		</div>
	</section>
</BaseLayout>
